/* LLM Forge — Polished dark theme */

Screen {
    background: $surface;
}

/* ── Chat Screen ─────────────────────────────────────────────────────── */

#chat-container {
    layout: horizontal;
    height: 1fr;
}

#messages-panel {
    width: 3fr;
    min-width: 40;
}

#profiler-panel {
    width: 1fr;
    min-width: 24;
    max-width: 40;
    border-left: thick $primary-background-darken-2;
}

#message-list {
    height: 1fr;
    overflow-y: auto;
    padding: 0 1;
}

.message-row {
    margin-bottom: 1;
    padding: 0 1;
}

.message-role-user {
    background: $primary-background-darken-3;
    border-left: thick $accent;
}

.message-role-assistant {
    background: $surface-darken-1;
    border-left: thick $success;
}

.message-role-system {
    background: $surface-darken-2;
    border-left: thick $warning;
    color: $text-muted;
}

.role-badge {
    text-style: bold;
    padding: 0 1;
    margin-bottom: 0;
}

.role-badge-user {
    color: $text;
    background: $accent;
}

.role-badge-assistant {
    color: $text;
    background: $success;
}

.message-content {
    padding: 0 1;
    margin-top: 0;
}

#input-area {
    dock: bottom;
    height: auto;
    max-height: 8;
    border-top: thick $primary-background-darken-2;
    padding: 0 1;
}

#chat-input {
    height: auto;
    min-height: 1;
    max-height: 6;
    border: none;
    background: $surface;
}

#status-bar {
    dock: bottom;
    height: 1;
    background: $primary-background-darken-3;
    color: $text-muted;
    padding: 0 1;
}

.status-streaming {
    color: $success;
    text-style: bold;
}

.status-idle {
    color: $text-muted;
}

/* ── Profiler Panel ──────────────────────────────────────────────────── */

#profiler-title {
    text-style: bold;
    color: $warning;
    text-align: center;
    padding: 0 0 1 0;
}

.metric-label {
    color: $text-muted;
}

.metric-value {
    text-style: bold;
}

.metric-tps-fast {
    color: $success;
}

.metric-tps-medium {
    color: #b4dc64;
}

.metric-tps-slow {
    color: $warning;
}

.metric-tps-very-slow {
    color: $error;
}

#gauge-gpu {
    margin: 0 1;
}

#gauge-ram {
    margin: 0 1;
}

.sparkline-container {
    height: 3;
    margin: 0 1;
    padding: 0;
}

.sparkline-title {
    color: $text-muted;
    text-style: italic;
}

/* ── Welcome screen ──────────────────────────────────────────────────── */

#welcome {
    align: center middle;
    width: 100%;
    height: 100%;
}

#welcome-box {
    width: 60;
    height: auto;
    border: round $primary;
    padding: 1 2;
    background: $surface-darken-1;
}

#welcome-title {
    text-align: center;
    text-style: bold;
    color: $accent;
    margin-bottom: 1;
}

#welcome-subtitle {
    text-align: center;
    color: $text-muted;
    margin-bottom: 1;
}

.welcome-hint {
    color: $text-muted;
    margin-left: 2;
}

.welcome-key {
    color: $accent;
    text-style: bold;
}

/* ── Model Library ───────────────────────────────────────────────────── */

#model-table {
    height: 1fr;
}

.fit-green {
    color: $success;
}

.fit-yellow {
    color: $warning;
}

.fit-red {
    color: $error;
}

/* ── Compare Screen ──────────────────────────────────────────────────── */

#compare-container {
    layout: horizontal;
    height: 1fr;
}

.compare-column {
    width: 1fr;
    border-right: thick $primary-background-darken-2;
    padding: 0 1;
    overflow-y: auto;
}

.compare-header {
    text-style: bold;
    color: $accent;
    text-align: center;
    padding: 0 0 1 0;
    border-bottom: solid $primary-background-darken-2;
}

.compare-metrics {
    dock: bottom;
    height: 3;
    border-top: solid $primary-background-darken-2;
    padding: 0 1;
    background: $surface-darken-1;
}

/* ── Experiments ─────────────────────────────────────────────────────── */

#experiments-table {
    height: 1fr;
}

#run-detail {
    height: 1fr;
    padding: 1;
    overflow-y: auto;
}

/* ── Sessions ────────────────────────────────────────────────────────── */

#sessions-table {
    height: 1fr;
}

#session-preview {
    padding: 1;
    overflow-y: auto;
}

/* ── Parameter Sweep ─────────────────────────────────────────────────── */

#sweep-config {
    border-bottom: thick $primary-background-darken-2;
    padding: 1;
    height: auto;
}

#sweep-table {
    height: 1fr;
}

#sweep-detail {
    height: 12;
    border-top: thick $primary-background-darken-2;
    padding: 1;
    overflow-y: auto;
}

/* ── Command Palette ─────────────────────────────────────────────────── */

CommandPalette {
    layer: overlay;
}

/* ── DataTable common styles ─────────────────────────────────────────── */

DataTable > .datatable--header {
    background: $primary-background-darken-2;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: $accent 30%;
}

/* ── Markdown rendering in chat ──────────────────────────────────────── */

Markdown {
    margin: 0;
    padding: 0;
}

MarkdownH1 {
    margin: 1 0 0 0;
}

MarkdownH2 {
    margin: 1 0 0 0;
}

MarkdownFence {
    margin: 1 0;
    padding: 1;
    background: $primary-background-darken-3;
}
